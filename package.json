{
  "name": "siyuan-mcp-plus",
  "version": "1.0.0",
  "description": "Enhanced SiYuan Note MCP Server with Cloud Support - 增强版思源笔记 MCP 服务，支持云端 API",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "siyuan-mcp-plus": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "siyuan",
    "mcp",
    "siyuan-cloud",
    "model-context-protocol",
    "note-taking",
    "api",
    "typescript"
  ],
  "author": "siink220920",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
